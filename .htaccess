RewriteEngine On

# =====================================================================
#  CANONICALISATION : forcer HTTPS + version sans www
#  (le site indexûˋ par Google est https://archi-truc-beziers.com sans www)
# =====================================================================
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^ https://archi-truc-beziers.com%{REQUEST_URI} [R=301,L]

# =====================================================================
#  PAGE 404 PERSONNALISûE
# =====================================================================
ErrorDocument 404 /404.html

# =====================================================================
#  ANCIENS PROJETS (portfolio WordPress) -> page projet dynamique
#  RewriteRule + QSD : fiable avec une query string (contrairement û  Redirect)
#  gû´re l'URL avec ou sans slash final
# =====================================================================
RewriteRule ^hotel-particulier/?$              /projet.html?id=hotel-particulier [R=301,L,QSD]
RewriteRule ^appartement-lago-villa-guy/?$     /projet.html?id=appartement-lago-villa-guy [R=301,L,QSD]
RewriteRule ^appartement-nimes/?$              /projet.html?id=appartement-nimes [R=301,L,QSD]
RewriteRule ^souki-lodge/?$                    /projet.html?id=souki-lodge [R=301,L,QSD]
RewriteRule ^lago-welcome-cap-dagde/?$         /projet.html?id=lago-cap-dagde [R=301,L,QSD]
RewriteRule ^bureau-nemesis/?$                 /projet.html?id=bureaux [R=301,L,QSD]
RewriteRule ^projet-photo/?$                   /projet.html?id=projet-photo [R=301,L,QSD]
RewriteRule ^hotel-la-prison-a-beziers/?$      /projet.html?id=hotel-la-prison [R=301,L,QSD]
RewriteRule ^maison-cersoise/?$                /projet.html?id=maison-cersoise [R=301,L,QSD]
RewriteRule ^mediatheque-beziers/?$            /projet.html?id=mediatheque-beziers [R=301,L,QSD]
RewriteRule ^projet-maison-a-cers/?$           /projet.html?id=maison-coloree [R=301,L,QSD]
RewriteRule ^technilum/?$                      /projet.html?id=technilum [R=301,L,QSD]
RewriteRule ^la-maison-dagde/?$                /projet.html?id=maison-dagde [R=301,L,QSD]
RewriteRule ^perspective-cassina-a-la-villa-guy/?$ /projet.html?id=cassina-villa-guy [R=301,L,QSD]

# --- Projets WordPress qui n'existent plus sur le nouveau site ---
# (aucune fiche ûˋquivalente -> on ûˋvite un soft 404 en pointant vers la liste)
RewriteRule ^clinique-veterinaire/?$           /nos-realisations.html [R=301,L]
RewriteRule ^cabinet-darchitecte/?$            /nos-realisations.html [R=301,L]

# =====================================================================
#  PAGES PRINCIPALES
# =====================================================================
Redirect 301 /nos-realisations/particuliers/ /nos-realisations.html
Redirect 301 /nos-realisations/professionnels/ /archi-business.html
Redirect 301 /nos-realisations/ /nos-realisations.html
Redirect 301 /archi-nous/ /archi-nous.html
Redirect 301 /archi-business/ /archi-business.html
Redirect 301 /nos-magasins/ /showrooms.html
Redirect 301 /contact/ /contact.html
Redirect 301 /mentions-legales/ /mentions-legales.html
Redirect 301 /location/ /location.html
Redirect 301 /engagements-rse/ /engagements-rse.html
Redirect 301 /archi-bonne-annee/ /archi-bonne-annee.html

# =====================================================================
#  MARQUES (toutes les sous-catûˋgories -> page globale)
# =====================================================================
RedirectMatch 301 ^/nos-marques(/.*)?$ /marques.html
Redirect 301 /tables/ /marques.html

# =====================================================================
#  NETTOYAGE DIVERS
# =====================================================================
Redirect 301 /braderie/ /

# =====================================================================
#  MISE EN CACHE DES RESSOURCES (Gain de performance OVH)
# =====================================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 month"
    
    # Images & VidÕos
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType video/mp4 "access plus 1 year"
    
    # Polices
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    
    # CSS & JS
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    
    # HTML
    ExpiresByType text/html "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
    <FilesMatch "\.(html|htm|xml|txt)$">
        Header set Cache-Control "max-age=3600, must-revalidate"
    </FilesMatch>
    
    <FilesMatch "\.(css|js|json)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
    
    <FilesMatch "\.(jpg|jpeg|png|gif|svg|webp|woff|woff2|mp4)$">
        Header set Cache-Control "max-age=31536000, public"
    </FilesMatch>
</IfModule>
